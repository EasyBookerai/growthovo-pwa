# ============================================================================
# ROOT .gitignore - GROWTHOVO Repository
# ============================================================================

# ----------------------------------------------------------------------------
# 🔒 Environment Variables & Secrets
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.secret
*.key

# ----------------------------------------------------------------------------
# 📦 Dependencies
# ----------------------------------------------------------------------------
node_modules/
**/node_modules/

# ----------------------------------------------------------------------------
# 🏗️ Build & Cache
# ----------------------------------------------------------------------------
dist/
build/
.cache/
*.cache

# ----------------------------------------------------------------------------
# 📝 Logs
# ----------------------------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------------------------
# 💻 OS Files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*~

# ----------------------------------------------------------------------------
# 🛠️ IDE
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------------------------------------------------------
# 🧪 Testing
# ----------------------------------------------------------------------------
coverage/
test_output*.txt
test-out*.txt
*.test.log

# ----------------------------------------------------------------------------
# 📚 Keep Documentation
# ----------------------------------------------------------------------------
!*.md
!README.md
