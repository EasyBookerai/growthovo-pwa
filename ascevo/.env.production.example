# ============================================================================
# GROWTHOVO PWA - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all environment variables needed for production deployment
# Copy this to .env.production and fill in your actual values
# NEVER commit .env.production to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
# Required for: Database, Authentication, Storage, Edge Functions

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (BACKEND ONLY - Never expose to client!)
# Set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-key
# Used in: Edge Functions for admin operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# OPENAI CONFIGURATION
# ----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
# Required for: Rex AI Coach, Morning Briefings, Speech Analysis, SOS Responses
# Cost: ~$0.002 per 1K tokens (GPT-4o-mini) or ~$0.03 per 1K tokens (GPT-4)
# Expected monthly cost: $50-500 depending on user base

OPENAI_API_KEY=sk-proj-...
# Set via: supabase secrets set OPENAI_API_KEY=sk-proj-...

# Optional: Specify model (defaults to gpt-4o-mini for cost efficiency)
OPENAI_MODEL=gpt-4o-mini
# Alternatives: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# Optional: Organization ID (if using organization account)
OPENAI_ORG_ID=org-...

# ----------------------------------------------------------------------------
# STRIPE CONFIGURATION
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
# Required for: Subscription payments, customer portal

# PUBLIC KEYS (Safe to expose to client)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# PRICE IDs (Get from: https://dashboard.stripe.com/products)
EXPO_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
EXPO_PUBLIC_STRIPE_PRICE_ANNUAL=price_...

# SECRET KEYS (BACKEND ONLY - Never expose to client!)
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook Secret (Get from: https://dashboard.stripe.com/webhooks)
# Set via: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# WEB PUSH NOTIFICATIONS (PWA)
# ----------------------------------------------------------------------------
# Generate VAPID keys using: npx web-push generate-vapid-keys
# Required for: Browser push notifications on web

EXPO_PUBLIC_WEB_PUSH_PUBLIC_KEY=BG...
# Set via: supabase secrets set WEB_PUSH_PRIVATE_KEY=...
WEB_PUSH_PRIVATE_KEY=...

# Contact email for push notifications (required by spec)
WEB_PUSH_CONTACT_EMAIL=support@growthovo.com

# ----------------------------------------------------------------------------
# HOSTING & DEPLOYMENT
# ----------------------------------------------------------------------------
# Platform: Vercel / Netlify / Cloudflare Pages

# Custom domain
EXPO_PUBLIC_APP_URL=https://app.growthovo.com
EXPO_PUBLIC_WEBSITE_URL=https://growthovo.com

# API Base URL (usually same as Supabase URL)
EXPO_PUBLIC_API_URL=https://your-project-id.supabase.co

# ----------------------------------------------------------------------------
# ANALYTICS & MONITORING
# ----------------------------------------------------------------------------

# Google Analytics (Optional)
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-...

# Plausible Analytics (Privacy-friendly alternative)
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=growthovo.com

# Sentry Error Tracking
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=your-org
SENTRY_PROJECT=growthovo

# ----------------------------------------------------------------------------
# EMAIL SERVICES (Optional but recommended)
# ----------------------------------------------------------------------------
# For legal document updates, password resets, etc.

# Resend (Recommended - https://resend.com)
RESEND_API_KEY=re_...
# Set via: supabase secrets set RESEND_API_KEY=re_...

# SendGrid (Alternative)
# SENDGRID_API_KEY=SG...

# Email sender configuration
EMAIL_FROM=noreply@growthovo.com
EMAIL_FROM_NAME=Growthovo

# ----------------------------------------------------------------------------
# STORAGE & CDN
# ----------------------------------------------------------------------------

# Supabase Storage bucket names
EXPO_PUBLIC_STORAGE_BUCKET_AVATARS=avatars
EXPO_PUBLIC_STORAGE_BUCKET_VIDEOS=time-capsules
EXPO_PUBLIC_STORAGE_BUCKET_AUDIO=speaking-recordings

# CDN URL (if using custom CDN)
# EXPO_PUBLIC_CDN_URL=https://cdn.growthovo.com

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------

# JWT Secret (for custom auth if needed)
# JWT_SECRET=your-super-secret-key-min-32-chars

# Encryption key for sensitive data
# ENCRYPTION_KEY=your-encryption-key-32-chars

# Rate limiting (requests per minute)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------

# Enable/disable features in production
EXPO_PUBLIC_ENABLE_PWA=true
EXPO_PUBLIC_ENABLE_WEB_PUSH=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_SPEAKING_TRAINER=true
EXPO_PUBLIC_ENABLE_TIME_CAPSULES=true

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------

NODE_ENV=production
EXPO_PUBLIC_ENV=production

# ----------------------------------------------------------------------------
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ----------------------------------------------------------------------------

# OpenAI TTS (Text-to-Speech) for audio generation
# Uses same OPENAI_API_KEY, but can specify voice
OPENAI_TTS_VOICE=alloy
# Options: alloy, echo, fable, onyx, nova, shimmer

# Deepgram (Alternative for speech-to-text)
# DEEPGRAM_API_KEY=...

# Cloudflare (if using Cloudflare Pages)
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_API_TOKEN=...

# ----------------------------------------------------------------------------
# DEVELOPMENT OVERRIDES (Remove in production)
# ----------------------------------------------------------------------------

# Uncomment for local testing with production-like setup
# EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

