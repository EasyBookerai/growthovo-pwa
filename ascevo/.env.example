# ============================================================================
# GROWTHOVO PWA - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this to .env for development OR .env.production for production
# See STRIPE_SETUP_GUIDE.md for how to get Stripe Price IDs
# ============================================================================

# ----------------------------------------------------------------------------
# 🔵 SUPABASE - Database, Auth, Storage (REQUIRED)
# ----------------------------------------------------------------------------
# Get from: https://app.supabase.com/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# 🤖 OPENAI - AI Features (REQUIRED)
# ----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
# Cost: ~$0.002 per 1K tokens (GPT-4o-mini)
# Set via: supabase secrets set OPENAI_API_KEY=sk-proj-...

OPENAI_API_KEY=sk-proj-...

# Optional: Specify model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# 💳 STRIPE - Payments (REQUIRED)
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
# See STRIPE_SETUP_GUIDE.md for detailed instructions

# PUBLIC KEYS (safe to expose in browser)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
EXPO_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
EXPO_PUBLIC_STRIPE_PRICE_ANNUAL=price_...

# SECRET KEYS (backend only - set via supabase secrets)
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 📝 HOW TO GET STRIPE PRICE IDs:
# 1. Go to https://dashboard.stripe.com/products
# 2. Click "+ Add product"
# 3. Create "Monthly" product: $9.99/month
# 4. Copy the Price ID (starts with price_...)
# 5. Create "Annual" product: $99.99/year
# 6. Copy the Price ID (starts with price_...)
# See STRIPE_SETUP_GUIDE.md for step-by-step instructions!

# ----------------------------------------------------------------------------
# 🔔 WEB PUSH NOTIFICATIONS - PWA Only (OPTIONAL)
# ----------------------------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys

EXPO_PUBLIC_WEB_PUSH_PUBLIC_KEY=BG...
WEB_PUSH_PRIVATE_KEY=...
WEB_PUSH_CONTACT_EMAIL=support@growthovo.com

# ----------------------------------------------------------------------------
# 🌐 HOSTING & DEPLOYMENT (OPTIONAL)
# ----------------------------------------------------------------------------

EXPO_PUBLIC_APP_URL=https://app.growthovo.com
EXPO_PUBLIC_WEBSITE_URL=https://growthovo.com

# ----------------------------------------------------------------------------
# 📊 MONITORING & ANALYTICS (OPTIONAL)
# ----------------------------------------------------------------------------

# Sentry - Error tracking
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Google Analytics
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-...

# Plausible Analytics (privacy-friendly alternative)
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=growthovo.com

# ----------------------------------------------------------------------------
# 📧 EMAIL SERVICE (OPTIONAL)
# ----------------------------------------------------------------------------

# Resend (recommended - free tier: 3K emails/month)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@growthovo.com

# ----------------------------------------------------------------------------
# ⚙️ FEATURE FLAGS
# ----------------------------------------------------------------------------

EXPO_PUBLIC_ENABLE_PWA=true
EXPO_PUBLIC_ENABLE_WEB_PUSH=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# ----------------------------------------------------------------------------
# 🔧 ENVIRONMENT
# ----------------------------------------------------------------------------

NODE_ENV=production
EXPO_PUBLIC_ENV=production

# ----------------------------------------------------------------------------
# 📝 SUPABASE SECRETS (Set via CLI)
# ----------------------------------------------------------------------------
# Run these commands to set backend-only secrets:
#
# supabase secrets set OPENAI_API_KEY=sk-proj-...
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=eyJ...
# supabase secrets set WEB_PUSH_PRIVATE_KEY=...
# supabase secrets set RESEND_API_KEY=re_...
#
# Verify with: supabase secrets list

# ----------------------------------------------------------------------------
# 🧪 DEVELOPMENT vs PRODUCTION
# ----------------------------------------------------------------------------
# DEVELOPMENT:
# - Use pk_test_... and sk_test_... for Stripe
# - Test cards: 4242 4242 4242 4242 (success)
# - Set NODE_ENV=development
#
# PRODUCTION:
# - Use pk_live_... and sk_live_... for Stripe
# - Real cards only
# - Set NODE_ENV=production
# - Deploy with: vercel --prod or netlify deploy --prod

# ----------------------------------------------------------------------------
# 📚 HELPFUL GUIDES
# ----------------------------------------------------------------------------
# - STRIPE_SETUP_GUIDE.md - How to get Stripe Price IDs
# - PWA_ONLY_SETUP.md - Quick setup guide (1-2 hours)
# - COST_CALCULATOR.md - Monthly cost estimates
# - STRIPE_QUICK_REFERENCE.md - Quick Stripe cheat sheet
