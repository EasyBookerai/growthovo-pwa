# ============================================================================
# GROWTHOVO PWA - PRODUCTION ENVIRONMENT (WEB ONLY)
# ============================================================================
# This is a simplified version for PWA-only deployment
# No native mobile app keys needed!
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (Required)
# ----------------------------------------------------------------------------
# Get from: https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# OPENAI (Required)
# ----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
# Set via: supabase secrets set OPENAI_API_KEY=sk-proj-...
OPENAI_API_KEY=sk-proj-...

# Optional: Specify model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# STRIPE (Required)
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys

# PUBLIC (safe to expose)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
EXPO_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
EXPO_PUBLIC_STRIPE_PRICE_ANNUAL=price_...

# SECRET (backend only - set via supabase secrets)
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# WEB PUSH NOTIFICATIONS (PWA Only)
# ----------------------------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
EXPO_PUBLIC_WEB_PUSH_PUBLIC_KEY=BG...
WEB_PUSH_PRIVATE_KEY=...
WEB_PUSH_CONTACT_EMAIL=support@growthovo.com

# ----------------------------------------------------------------------------
# HOSTING & DEPLOYMENT
# ----------------------------------------------------------------------------
EXPO_PUBLIC_APP_URL=https://app.growthovo.com
EXPO_PUBLIC_WEBSITE_URL=https://growthovo.com

# ----------------------------------------------------------------------------
# OPTIONAL: MONITORING
# ----------------------------------------------------------------------------

# Sentry (Error tracking)
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Analytics (Choose one)
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-...
# OR
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=growthovo.com

# ----------------------------------------------------------------------------
# OPTIONAL: EMAIL SERVICE
# ----------------------------------------------------------------------------
# Resend (recommended)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@growthovo.com

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
EXPO_PUBLIC_ENABLE_PWA=true
EXPO_PUBLIC_ENABLE_WEB_PUSH=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------
NODE_ENV=production
EXPO_PUBLIC_ENV=production

# ----------------------------------------------------------------------------
# SUPABASE SECRETS (Set via CLI)
# ----------------------------------------------------------------------------
# Run these commands to set backend secrets:
# supabase secrets set OPENAI_API_KEY=sk-proj-...
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=eyJ...
# supabase secrets set WEB_PUSH_PRIVATE_KEY=...
# supabase secrets set RESEND_API_KEY=re_...

